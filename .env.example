# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only commit .env.example
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=hub10
DB_PORT=5434

# Prisma reads this directly (auto-constructed in docker-compose)
DATABASE_URL=postgresql://postgres:your_strong_password_here@localhost:5434/hub10

# ── JWT ───────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=development

# ── Mail (SMTP) ────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM_NAME=Hub-10
MAIL_FROM_ADDRESS=your_email@gmail.com
